{
  "name": "clipnote",
  "version": "1.0.0",
  "description": "本地剪贴板笔记 + AI 助手",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "concurrently \"vite\" \"npm run electron:dev\"",
    "electron:dev": "wait-on http://localhost:5173 && cross-env NODE_ENV=development electron .",
    "build": "vite build && tsc -p tsconfig.electron.json && electron-builder",
    "build:win": "vite build && tsc -p tsconfig.electron.json && electron-builder --win",
    "electron:build": "tsc -p tsconfig.electron.json"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "@vitejs/plugin-react": "^4.0.0",
    "concurrently": "^8.0.0",
    "cross-env": "^7.0.0",
    "electron": "^31.0.0",
    "electron-builder": "^24.9.0",
    "typescript": "^5.0.0",
    "vite": "^5.0.0",
    "vite-plugin-electron": "^0.28.0",
    "wait-on": "^7.0.0"
  },
  "dependencies": {
    "@codemirror/lang-markdown": "^6.2.0",
    "@codemirror/language-data": "^6.3.0",
    "@codemirror/theme-one-dark": "^6.1.0",
    "@uiw/react-codemirror": "^4.21.0",
    "codemirror": "^6.0.0",
    "electron-store": "^8.2.0",
    "marked": "^9.1.0",
    "marked-highlight": "^2.1.0",
    "highlight.js": "^11.9.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "zustand": "^4.4.0"
  }
}
